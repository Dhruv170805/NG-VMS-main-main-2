# ==========================================
# NG-VMS ENTERPRISE ON-PREM CONFIGURATION
# ==========================================

# --- SYSTEM SETTINGS ---
PORT=5000
NODE_ENV=production
JWT_SECRET=generate_a_secure_random_string_here
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d
JWT_ACCESS_EXPIRE_MS=900000
JWT_REFRESH_EXPIRE_MS=2592000000
DEFAULT_HOST_PASSWORD=Welcome@123
RATE_LIMIT_GLOBAL=1000
RATE_LIMIT_AUTH=20
EXTRA_ALLOWED_ORIGINS=http://your-custom-domain.com

# --- DATABASE (REPLICA SET) ---
# For on-prem high availability
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=change_this_to_a_strong_password
MONGDB_URI=mongodb://admin:change_this_to_a_strong_password@mongo:27017/ngvms?authSource=admin&replicaSet=rs0
REDIS_PASSWORD=change_this_to_a_strong_redis_password
REDIS_URL=redis://:change_this_to_a_strong_redis_password@redis:6379

# --- LOCAL OBJECT STORAGE (MINIO) ---
# Enterprise requirement: Use MinIO instead of AWS S3
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=ngvmsadmin
MINIO_SECRET_KEY=change_this_to_a_strong_minio_password
MINIO_BUCKET=ngvms-assets

# --- LOCAL SMTP ---
# For offline email notifications
SMTP_HOST=smtp_relay
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@ng-vms.enterprise

# --- NETWORKING & PROXY ---
# Caddy handles SSL and routing automatically
DOMAIN_NAME=vms.client.com
TLS_EMAIL=admin@client.com
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_SOCKET_URL=/

# --- LICENSE SYSTEM (OFFLINE) ---
# Enterprise signed offline license_NGS.lic
LICENSE_KEY_PATH=./_NGS.lic
# 32-char secret for verifying the RSA/HMAC signature
LICENSE_SECRET=default-secret-key-123
ENCRYPTION_KEY=your_production_encryption_32_byte_key
SKIP_HW_LOCK=false
ALLOW_UNSIGNED_LICENSE=false
DEPLOYMENT_MODE=ON_PREM

# --- MONITORING ---
GRAFANA_PASSWORD=change_this_to_a_strong_password
